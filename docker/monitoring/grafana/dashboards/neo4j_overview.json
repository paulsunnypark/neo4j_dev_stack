{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Neo4j Dev Stack 모니터링 대시보드",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Outbox — Pending",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "mappings": [],
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "outbox_pending_count",
          "legendFormat": "Pending",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Outbox — 처리 속도 (건/분)",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 4 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(outbox_processed_total[1m]) * 60",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Outbox — 실패 누계",
      "type": "stat",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(outbox_failed_total) or vector(0)",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Outbox — 이벤트 타입별 실패",
      "type": "timeseries",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "options": { "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(outbox_failed_total[5m]) * 60",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Neo4j — Transactions Committed/s",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(neo4j_transaction_committed_total[1m])",
          "legendFormat": "Committed/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(neo4j_transaction_rolled_back_total[1m])",
          "legendFormat": "Rolled Back/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Neo4j — Page Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neo4j_page_cache_hit_ratio",
          "legendFormat": "Hit Ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Neo4j — Heap Memory",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 6 },
      "options": { "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 900000000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neo4j_vm_heap_used",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neo4j_vm_heap_committed",
          "legendFormat": "Heap Committed",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Neo4j — Active Bolt Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 5 },
      "options": { "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neo4j_bolt_connections_running",
          "legendFormat": "Running",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neo4j_bolt_connections_opened_total",
          "legendFormat": "Opened Total",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Neo4j — Store Sizes",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 5 },
      "options": { "tooltip": { "mode": "single" } },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neo4j_store_size_total",
          "legendFormat": "Total Store Size",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["neo4j", "outbox", "fastapi"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Neo4j Dev Stack Overview",
  "uid": "neo4j-dev-overview",
  "version": 1
}
